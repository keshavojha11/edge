generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Market {
  id            String    @id @default(cuid())
  venue         String
  venueMarketId String
  title         String
  outcomesJson  String
  closeTime     DateTime?
  liquidity     Float?
  isPlayMoney   Boolean   @default(false)
  runId         String?
  snapshotAt    DateTime  @default(now())
  url           String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([venue, venueMarketId])
  @@index([venue])
  @@index([snapshotAt])
  @@index([runId])
}

model MatchGroup {
  id               String   @id @default(cuid())
  label            String
  marketIds        String
  matchConfidence  Float
  notedDifferences String
  maxSpread        Float
  realMoneySpread  Float    @default(0)
  runId            String?
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())

  watches Watch[]

  @@index([realMoneySpread])
  @@index([maxSpread])
  @@index([runId])
}

model Watch {
  id           String     @id @default(cuid())
  matchGroupId String
  thresholdPct Float
  status       String     @default("active")
  lastSpread   Float?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  matchGroup MatchGroup @relation(fields: [matchGroupId], references: [id], onDelete: Cascade)

  @@index([status])
}

model Event {
  id           String   @id @default(cuid())
  type         String
  detail       String
  creditsSpent Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([type])
  @@index([createdAt])
}

// Cached payload for each non-market panel (macro indicator, trending list,
// news feed). Served on page load — NEVER fetched per request. Refreshed by
// the live run + scheduled cron.
model PanelCache {
  key          String   @id // e.g. "vix", "coins", "trending:kalshi", "news:cnbc"
  payloadJson  String
  creditsSpent Int      @default(0)
  fetchedAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Async live-ingest run tracking ─────────────────────────────────────────────

model Run {
  id        String      @id @default(cuid())
  status    String      @default("running") // running | matching | completed | failed
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  jobs IngestJob[]

  @@index([status])
  @@index([createdAt])
}

model IngestJob {
  id        String   @id @default(cuid())
  runId     String
  venue     String
  kind      String   // selects the normalizer (see lib/targets.ts)
  event     String   // logical event the job contributes to
  label     String   // human label for progress UI
  wireJobId String
  status    String   @default("pending") // pending | completed | failed
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  run Run @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([status])
}
